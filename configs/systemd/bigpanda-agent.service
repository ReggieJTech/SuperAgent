[Unit]
Description=BigPanda Super Agent
Documentation=https://docs.bigpanda.io/super-agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=bigpanda
Group=bigpanda

# Binary and config
ExecStart=/opt/bigpanda-agent/bigpanda-agent -config /etc/bigpanda-agent/config.yaml
ExecReload=/bin/kill -HUP $MAINPID

# Working directory
WorkingDirectory=/opt/bigpanda-agent

# Restart policy
Restart=on-failure
RestartSec=5s
StartLimitInterval=60s
StartLimitBurst=3

# Resource limits
LimitNOFILE=65536
LimitNPROC=512

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/bigpanda-agent /var/log/bigpanda-agent
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
RestrictRealtime=true
RestrictNamespaces=true
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
SystemCallArchitectures=native

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=bigpanda-agent

# Capabilities (needed for binding to port 162)
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE

[Install]
WantedBy=multi-user.target
